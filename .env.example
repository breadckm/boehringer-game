# Supabase — 게임별 점수/세이브 저장 + 브라우저 Realtime
# SUPABASE_KEY: Publishable(anon) 키 — 브라우저(game.js)에 주입되므로 노출 안전
# SUPABASE_SERVICE_KEY: Secret 키 — 서버에서 RLS 우회·관리 작업 시만 사용
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_KEY=sb_publishable_your_key_here
SUPABASE_SERVICE_KEY=sb_secret_your_key_here

# 세션 쿠키 서명 키 — 운영 환경에선 반드시 임의의 긴 문자열로 교체
SECRET_KEY=change-me-to-a-long-random-string
